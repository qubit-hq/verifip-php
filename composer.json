{
    "name": "qubit-hq/verifip",
    "description": "Official PHP SDK for the VerifIP IP fraud scoring API",
    "type": "library",
    "license": "MIT",
    "keywords": ["verifip", "ip", "fraud", "proxy", "vpn", "tor", "security"],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "VerifIP\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VerifIP\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
